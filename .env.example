# [runtime] Runtime
# Runtime cache directory override.
# policy: optional, non-sensitive
RUNTIME_CACHE_DIR=.runtime-cache/cache
# Canonical number of latest run artifact directories to keep.
# policy: optional, non-sensitive
RUNTIME_GC_KEEP_RUNS=50
# Canonical number of latest CI artifact entries to keep under .runtime-cache/artifacts/ci.
# policy: optional, non-sensitive
RUNTIME_GC_CI_KEEP_COUNT=30
# Retention window in days for CI artifact entries under .runtime-cache/artifacts/ci.
# policy: optional, non-sensitive
RUNTIME_GC_CI_RETENTION_DAYS=14
# Default runtime-gc cleanup scope (logs|runs|cache|dev|mcp|automation|backups|all).
# policy: optional, non-sensitive
RUNTIME_GC_SCOPE=all
# Trigger cleanup for dev/mcp/automation/backups when directory size reaches threshold MB.
# policy: optional, non-sensitive
RUNTIME_GC_DIR_SIZE_THRESHOLD_MB=256
# Maximum delete operations allowed in a single runtime-gc execution.
# policy: optional, non-sensitive
RUNTIME_GC_MAX_DELETE_PER_RUN=500
# Runtime GC state output path.
# policy: optional, non-sensitive
RUNTIME_GC_STATE_PATH=.runtime-cache/metrics/runtime-gc-state.json
# Runtime backup archive retention in days.
# policy: optional, non-sensitive
RUNTIME_BACKUP_RETENTION_DAYS=14
# Maximum number of runtime backup archives to keep.
# policy: optional, non-sensitive
RUNTIME_BACKUP_KEEP_COUNT=20
# Runtime log directory override.
# policy: optional, non-sensitive
RUNTIME_LOG_DIR=.runtime-cache/logs
# Upstream sync script variable for base branch.
# policy: optional, non-sensitive
BASE_BRANCH=
# Upstream sync script variable for generated sync branch.
# policy: optional, non-sensitive
SYNC_BRANCH=
# Upstream sync script variable for upstream branch.
# policy: optional, non-sensitive
UPSTREAM_BRANCH=main
# Upstream sync script variable for upstream ref.
# policy: optional, non-sensitive
UPSTREAM_REF=
# Upstream sync script variable for remote name.
# policy: optional, non-sensitive
UPSTREAM_REMOTE=upstream
# Upstream sync script variable for upstream URL.
# policy: optional, non-sensitive
UPSTREAM_URL=
# Script-local root variable detected by env governance scanner.
# policy: optional, non-sensitive
ROOT=
# Canonical pipeline narrative label used by run-pipeline scripts.
# policy: optional, non-sensitive
CANONICAL_PIPELINE_PATH=Flow -> Template -> Run
# Upstream source config required flag read by bootstrap scripts.
# policy: optional, non-sensitive
CONFIG_REQUIRED=true

# [frontend] Frontend
# Frontend source root override for CI inventory checks.
# policy: optional, non-sensitive
FRONTEND_SRC=apps/web/src
# Button inventory manifest file path override.
# policy: optional, non-sensitive
MANIFEST_FILE=apps/web/src/testing/button-manifest.ts

# [runtime] Runtime
# Upstream remote name parsed from source config.
# policy: optional, non-sensitive
REMOTE_NAME=upstream
# Backup output directory override for runtime backup scripts.
# policy: optional, non-sensitive
RUNTIME_BACKUP_DIR=
# Computed strict-mode flag used by upstream bootstrap scripts.
# policy: optional, non-sensitive
STRICT_FLAG=false
# Preflight total-step marker used for progress labeling.
# policy: optional, non-sensitive
TOTAL_STEPS=9

# [tests] Tests
# Optional desktop-only step ID registry (CSV or JSON).
# policy: optional, non-sensitive
UIQ_DESKTOP_ONLY_STEPS=desktop_readiness,desktop_smoke,desktop_e2e,desktop_business_regression,desktop_soak
# Driver capability registry file path override.
# policy: optional, non-sensitive
UIQ_DRIVER_CAPABILITIES_REGISTRY_FILE=configs/drivers/capabilities.registry.json
# Inline driver capability registry payload (JSON object).
# policy: optional, non-sensitive
UIQ_DRIVER_CAPABILITIES_REGISTRY_JSON=
# Preflight mode override: full or minimal.
# policy: optional, non-sensitive
UIQ_PREFLIGHT_MODE=full
# Profile registry directory override.
# policy: optional, non-sensitive
UIQ_PROFILE_REGISTRY_DIR=profiles
# Inline profile registry names (CSV or JSON array).
# policy: optional, non-sensitive
UIQ_PROFILE_REGISTRY_NAMES=
# Profile schema registry file path override.
# policy: optional, non-sensitive
UIQ_PROFILE_SCHEMA_REGISTRY_FILE=configs/schemas/profile.v1.schema.json
# Gate check registry IDs override (CSV or JSON array).
# policy: optional, non-sensitive
UIQ_RUN_GATE_CHECK_IDS=
# Enable orchestrator MCP suite in test matrix (0/1).
# policy: optional, non-sensitive
UIQ_SUITE_ORCHESTRATOR_MCP=1
# Swift desktop regression target bundle identifier.
# policy: optional, non-sensitive
UIQ_SWIFT_BUNDLE_ID=
# Target schema registry file path override.
# policy: optional, non-sensitive
UIQ_TARGET_SCHEMA_REGISTRY_FILE=configs/schemas/target.v1.schema.json
# Absolute app bundle path for Tauri desktop regression.
# policy: optional, non-sensitive
UIQ_TAURI_APP_PATH=

# [runtime] Runtime
# Legacy runtime base URL alias; prefer UIQ_BASE_URL.
# policy: optional, non-sensitive
BASE_URL=

# [tests] Tests
# Target driver identifier override for desktop smoke scripts.
# policy: optional, non-sensitive
DRIVER_ID=
# Target identifier override for manifest and smoke scripts.
# policy: optional, non-sensitive
TARGET_ID=
# Target platform override (web|tauri|swift).
# policy: optional, non-sensitive
TARGET_PLATFORM=
# Legacy Tauri app path alias for desktop webdriver scripts.
# policy: optional, non-sensitive
TAURI_APP_PATH=
# Optional JSON capabilities override for webdriver sessions.
# policy: optional, non-sensitive
WEBDRIVER_CAPABILITIES_JSON=
# Webdriver provider label for diagnostics.
# policy: optional, non-sensitive
WEBDRIVER_PROVIDER=
# Webdriver endpoint URL for desktop smoke scripts.
# policy: optional, non-sensitive
WEBDRIVER_URL=http://127.0.0.1:4444
# XCUITest build configuration override.
# policy: optional, non-sensitive
XCUITEST_CONFIGURATION=
# XCUITest destination override.
# policy: optional, non-sensitive
XCUITEST_DESTINATION=platform=macOS
# XCUITest execution mode (test|build-for-testing).
# policy: optional, non-sensitive
XCUITEST_MODE=test
# Comma-separated xcodebuild only-testing entries.
# policy: optional, non-sensitive
XCUITEST_ONLY_TESTING=
# XCUITest .xcodeproj path override.
# policy: optional, non-sensitive
XCUITEST_PROJECT=
# XCUITest scheme override.
# policy: optional, non-sensitive
XCUITEST_SCHEME=
# Comma-separated xcodebuild skip-testing entries.
# policy: optional, non-sensitive
XCUITEST_SKIP_TESTING=
# XCUITest test plan override.
# policy: optional, non-sensitive
XCUITEST_TEST_PLAN=
# XCUITest .xcworkspace path override.
# policy: optional, non-sensitive
XCUITEST_WORKSPACE=

# [runtime] Runtime
# Strict-mode toggle for upstream bootstrap (0/1).
# policy: optional, non-sensitive
UIQ_UPSTREAM_BOOTSTRAP_STRICT=0
# Upstream branch override for sync/bootstrap scripts.
# policy: optional, non-sensitive
UIQ_UPSTREAM_BRANCH=main
# Upstream repository URL override for sync/bootstrap scripts.
# policy: optional, sensitive
UIQ_UPSTREAM_REPO_URL=
# Upstream source config path override.
# policy: optional, non-sensitive
UIQ_UPSTREAM_SOURCE_CONFIG=configs/upstream/source.yaml

# [tests] Tests
# Optional web-only step ID registry (CSV or JSON).
# policy: optional, non-sensitive
UIQ_WEB_ONLY_STEPS=capture,explore,chaos,a11y,perf,visual,load

# [runtime] Runtime
# CLI-only upstream branch override marker for sync audits.
# policy: optional, non-sensitive
UPSTREAM_BRANCH_OVERRIDE=
