{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppConfig",
  "type": "object",
  "required": ["app_name", "environment", "backend"],
  "properties": {
    "app_name": { "type": "string" },
    "environment": { "type": "string" },
    "backend": {
      "type": "object",
      "required": ["host", "port"],
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    }
  }
}
