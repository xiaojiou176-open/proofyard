{
  "name": "@proofyard/automation-runner",
  "version": "0.1.0",
  "description": "Proofyard automation runner for recording, replay, and artifact-based reconstruction side roads",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "automation:convert:curl": "bash scripts/run-curlconverter-safe.sh",
    "tool:curlconverter": "pnpm run automation:convert:curl",
    "record": "node --import tsx scripts/record-session.ts",
    "record:manual": "node --import tsx scripts/record-session.ts --mode=manual",
    "record:cdp": "node --import tsx scripts/record-via-cdp.ts",
    "extract": "node --import tsx scripts/extract-flow-spec.ts",
    "extract:register": "node --import tsx scripts/extract-register-spec.ts",
    "extract:video": "node --import tsx scripts/extract-video-flow.ts",
    "report:ui-ux:gemini": "node --import tsx scripts/generate-ui-ux-gemini-report.ts",
    "generate-case": "node --import tsx scripts/generate-playwright-case.ts",
    "generate:reconstruction": "node --import tsx scripts/generate-from-reconstruction.ts",
    "replay": "node --import tsx scripts/replay-register.ts",
    "replay-flow": "node --import tsx scripts/replay-flow-draft.ts",
    "replay-flow-step": "node --import tsx scripts/replay-flow-step.ts",
    "reconstruct-and-replay": "node --import tsx scripts/reconstruct-and-replay.ts",
    "test": "playwright test"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "0.27.4",
    "@eslint/js": "9.39.4",
    "@google/genai": "1.42.0",
    "@playwright/test": "1.59.1",
    "@types/node": "25.2.3",
    "ajv": "8.18.0",
    "curlconverter": "4.12.0",
    "eslint": "9.39.4",
    "eslint-plugin-jest": "29.15.0",
    "globals": "16.5.0",
    "har-to-k6": "0.14.10",
    "playwright": "1.59.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
